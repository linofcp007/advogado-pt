# Artefactos de build
advogado-pt.skill
*.skill
/dist/

# Node
node_modules/
mcp-server/node_modules/

# Servidor MCP: o bundle self-contained `dist/index.js` e o conteúdo jurídico
# em `content/` SÃO versionados, para o plugin funcionar quando instalado via
# marketplace (não há `npm install` nesse fluxo). O resto de `dist/` (saída do
# tsc, usada só nos testes) é gerado e fica ignorado.
mcp-server/dist/*
!mcp-server/dist/index.js

# Python
**/__pycache__/
*.py[cod]

# Sistema operativo
.DS_Store
Thumbs.db

# dev-guardian outputs
.guardian/
